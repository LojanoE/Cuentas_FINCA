rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Función: ¿el usuario está autenticado?
    function isAuthenticated() {
      return request.auth != null;
    }

    // Función: ¿es el mismo usuario?
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Función: ¿es administrador?
    function isAdmin() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // Colección users: cada uno lee su propio documento, el admin lee/escribe todos
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
    }

    // Colección workers: el trabajador lee el suyo, el admin todo
    match /workers/{workerId} {
      allow read: if isAdmin() || isOwner(resource.data.userId);
      allow write: if isAdmin();
    }

    // Colección advances: el trabajador lee los suyos por userId, el admin todo, solo admin escribe
    match /advances/{advanceId} {
      allow read: if isAdmin() || isOwner(resource.data.userId);
      allow write: if isAdmin();
    }
  }
}
